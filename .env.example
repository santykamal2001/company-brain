# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=brain
POSTGRES_PASSWORD=changeme_strong_password_here

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: claude | openai | azure | ollama
LLM_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# OpenAI
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# LLM_MODEL=gpt-4o

# Ollama (local, no API key needed — start with --profile local-llm)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# LLM_MODEL=llama3

# ─── Extraction / Routing LLM (cheaper than generation model) ─────────────────
EXTRACTION_LLM_PROVIDER=claude
EXTRACTION_LLM_MODEL=claude-haiku-4-5

# ─── Contextual Retrieval ─────────────────────────────────────────────────────
CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXT_LLM_PROVIDER=claude
CONTEXT_LLM_MODEL=claude-haiku-4-5
CONTEXT_LLM_USE_PROMPT_CACHING=true
CONTEXT_LLM_USE_BATCH_API=true

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024

# ─── Chunking ─────────────────────────────────────────────────────────────────
PARENT_CHUNK_SIZE=3500
CHILD_CHUNK_SIZE=512
CHILD_CHUNK_OVERLAP=50

# ─── Graph Retrieval ──────────────────────────────────────────────────────────
GRAPH_ENABLED=true
GRAPH_CONTEXT_TOKEN_BUDGET=2000
GRAPH_TRAVERSAL_DEPTH=1

# ─── RBAC Defaults ────────────────────────────────────────────────────────────
DEFAULT_CLASSIFICATION=internal
# Comma-separated keywords that trigger confidential classification
CONFIDENTIAL_KEYWORDS=salary,compensation,offer letter,termination,attorney,legal hold,acquisition,merger

# ─── SSO ──────────────────────────────────────────────────────────────────────
SSO_ENABLED=false
SAML_METADATA_URL=
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
SCIM_ENABLED=false
SCIM_TOKEN=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme_at_least_32_chars_random_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Infrastructure ───────────────────────────────────────────────────────────
# Set automatically by docker-compose; override only if running outside Docker
# DATABASE_URL=postgresql+asyncpg://brain:changeme@localhost:5432/company_brain
# QDRANT_URL=http://localhost:6333
# REDIS_URL=redis://localhost:6379/0

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=500
